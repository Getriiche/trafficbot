# ============================================
# Veneno Traffic Bot v2 - Configuration
# ============================================

# [General]
NODE_ENV=production
LOG_LEVEL=info
URL=https://lucasveneno.com/
MAX_SESSIONS=1
STEALTH_MODE=true
HEADLESS=true
PERSISTENT_SESSIONS=false
SESSIONS_DATA_DIR=./sessions
SESSION_TIME=3
REFERRALS=no
HUMAN_BEHAVIOR=true
BEHAVIOR_INTENSITY=medium

# [Private Proxy List - RECOMMENDED]
# Format: host:port:user:pass (one per line)
# Example with session sticky support: proxy.com:1234:user:pass_session-{id}
# Supports any private proxy provider (Bright Data, Oxylabs, custom, etc.)
PROXY_LIST=proxy1.example.com:1234:username:password
# proxy2.example.com:1234:username:password
# proxy3.example.com:1234:username:password

# Alternative: Load from file
# PROXY_FILE=./proxy_list.txt

# [IPRoyal Web Unblocker - DEPRECATED]
# NOT compatible with Puppeteer/browser automation
# Only use for HTTP API scraping, not for this traffic bot
# IPROYAL_HOST=unblocker.iproyal.com
# IPROYAL_PORT=12323
# IPROYAL_USER=username
# IPROYAL_PASS=password

# [Single Proxy Fallback]
# Used only if PROXY_LIST is empty
PROXY_URL=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# [Redis - Required for distributed mode]
REDIS_URL=redis://:your_redis_password@localhost:6379

# [PBN Configuration]
PBN_ENABLED=true
PBN_SITES_CONFIG=./pbn-sites.json

# [Traffic Sources]
ORGANIC_SEARCH=false
SEARCH_KEYWORDS=web design,seo services,digital marketing
SEARCH_ENGINE=google
SEARCH_PAGES_LIMIT=2

# [Money Sites - Multiple supported]
MONEYSITE_URLS=https://lucasveneno.com/,https://example.com/
MONEYSITE_DURATION_MIN=90
MONEYSITE_DURATION_MAX=350
MAX_CONCURRENT_SITES=2

# [Funnel Templates]
FUNNEL_TEMPLATES=tier3-tier2-tier1-money,tier3-tier1-money,tier2-tier1-money
FUNNEL_HYBRID_MODE=false
FUNNEL_ORGANIC_PROBABILITY=0.4

# [Tier Configuration]
TIER3_DURATION_MIN=60
TIER3_DURATION_MAX=180
TIER2_DURATION_MIN=120
TIER2_DURATION_MAX=300
TIER1_DURATION_MIN=90
TIER1_DURATION_MAX=240

# [IPCook - DEPRECATED, use IPRoyal instead]
# These settings are kept for backward compatibility only
IPCOOK_PROXY_LIST=
IPCOOK_API_AUTH=
